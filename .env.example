# 智谱 AI API Key（必需）
ZHIPU_API_KEY=your_zhipu_api_key_here

# 数据库（Vercel Postgres）
# 在 Vercel 项目设置中添加 DATABASE_URL 环境变量
# 格式: postgresql://user:password@host:5432/database
DATABASE_URL=

# JWT 密钥（生产环境请修改）
JWT_SECRET=your-super-secret-key-change-in-production

# Prisma（Vercel Postgres 内置，不需要手动设置）
# 连接字符串由 Vercel 自动注入到 DATABASE_URL
